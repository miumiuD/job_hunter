    {
      "parameters": {
        "jsCode": "// 获取上游 Airtable 节点的所有结果\nconst allItems = $input.all();\n\n// 1. 初始化统计变量\nlet targetCount = 0;   \nlet suitableCount = 0; \nlet processedCount = allItems.length;\n\n// 2. 预处理数据：进入 fields 层级提取\nlet jobs = allItems.map(item => {\n  // 【关键点】从 fields 对象中取值\n  const f = item.json.fields || {}; \n  \n  // 转换分数 (适配你的字段名 AI_match_score)\n  const score = parseInt(f.AI_match_score) || 0;\n  \n  // 统计标签逻辑\n  const labels = f.AI_labels || \"\";\n  if (labels.includes(\"目标岗位\")) targetCount++;\n  if (labels.includes(\"适合岗位\")) suitableCount++;\n  \n  // 将所有字段拉平返回，方便后面 summaryList 使用\n  return {\n    title: f.title,\n    company: f.company,\n    location: f.location,\n    posted_at: f.created_at, // 映射 Airtable 里的 created_at\n    AI_requirements: f.AI_requirements,\n    url: f.url,\n    score: score\n  };\n});\n\n// 3. 排序逻辑：按分数从高到低\njobs.sort((a, b) => b.score - a.score);\n\n// 4. 获取前 5 个岗位\nconst top5 = jobs.slice(0, 5);\n\n// 5. 构建汇总列表\nlet summaryList = top5.map((job, index) => {\n  return `${index + 1}. **${job.title || '未知岗位'}** (评分: ${job.score})\\n` +\n         `   - **公司**: ${job.company || '未知'}\\n` +\n         `   - **地点**: ${job.location || '未知'}\\n` +\n         `   - **发布时间**: ${job.posted_at || '未知'}\\n` +\n         `   - **核心要求**: ${job.AI_requirements ? job.AI_requirements.substring(0, 80) + '...' : '无'}\\n` +\n         `   - **职位链接**: [点击查看](${job.url || '#'})`;\n}).join('\\n\\n');\n\n// 6. 返回最终日报结果\nreturn {\n  total_processed: processedCount,\n  target_total: targetCount,\n  suitable_total: suitableCount,\n  summary_report: `## 🚀 今日求职日报 (${$now.toFormat('yyyy-MM-dd')})\\n\\n` +\n                  `今天共处理了 **${processedCount}** 个岗位：\\n` +\n                  `- 🎯 **目标岗位**: ${targetCount} 个\\n` +\n                  `- ✅ **适合岗位**: ${suitableCount} 个\\n\\n` +\n                  `---\\n\\n` +\n                  `## 🔥 匹配度最高的前 5 个机会\\n\\n` +\n                  (summaryList || \"今天没有找到合适的岗位推荐。\")\n};"
      },
